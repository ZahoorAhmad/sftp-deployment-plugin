<idea-plugin>
    <id>com.wanclouds.sftpdeployment</id>
    <name>SFTP Deployment</name>
    <vendor email="support@wanclouds.net" url="https://www.wanclouds.net">WanClouds</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable
            parentId="tools"
            instance="com.wanclouds.sftpdeployment.ui.SftpSettingsConfigurable"
            id="com.wanclouds.sftpdeployment.ui.SftpSettingsConfigurable"
            displayName="SFTP Deployment"/>
        <projectService serviceImplementation="com.wanclouds.sftpdeployment.settings.SftpSettings"/>
        <notificationGroup id="SFTP Connection Test" displayType="BALLOON"/>

        <toolWindow id="SFTP Changes" 
                    anchor="left" 
                    factoryClass="com.wanclouds.sftpdeployment.ui.SftpToolWindowFactory"
                    icon="AllIcons.Actions.Upload"/>
    </extensions>

    <actions>
        <group id="SftpDeploymentMenu" text="SFTP Deployment" popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="ChangesViewPopupMenu" anchor="last"/>
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="last"/>
            <action id="SftpUploadAction" class="com.wanclouds.sftpdeployment.actions.UploadAction" text="Upload Selected via SFTP"/>
            <action id="SftpUploadAllChangedAction" class="com.wanclouds.sftpdeployment.actions.UploadAllChangedAction" text="⚡ Upload ALL Git Changes via SFTP"/>
            <action id="SftpDownloadAction" class="com.wanclouds.sftpdeployment.actions.DownloadAction" text="Download Selected via SFTP"/>
        </group>
    </actions>
</idea-plugin>
