<idea-plugin>
    <id>com.wanclouds.sftpdeployment</id>
    <name>SFTP Deployment</name>
    <vendor email="support@wanclouds.net" url="https://www.wanclouds.net">WanClouds</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable
            parentId="tools"
            instance="com.wanclouds.sftpdeployment.ui.SftpSettingsConfigurable"
            id="com.wanclouds.sftpdeployment.ui.SftpSettingsConfigurable"
            displayName="SFTP Deployment"/>
        <applicationService serviceImplementation="com.wanclouds.sftpdeployment.settings.SftpSettings"/>
        <notificationGroup id="SFTP Connection Test" displayType="BALLOON"/>
    </extensions>

    <actions>
        <group id="SftpDeploymentMenu" text="SFTP Deployment" popup="true">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <action id="SftpUploadAction" class="com.wanclouds.sftpdeployment.actions.UploadAction" text="Upload via SFTP"/>
            <action id="SftpDownloadAction" class="com.wanclouds.sftpdeployment.actions.DownloadAction" text="Download via SFTP"/>
        </group>
    </actions>
</idea-plugin>
